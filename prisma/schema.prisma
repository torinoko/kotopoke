generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Word {
  id           String @id
  text         String
  reading      String?
  source       String?
  meaning      String?
  impression   String?
  relatedWords String
  collectedAt  String
  userId       String?
  user         User?  @relation(fields: [userId], references: [id])

  @@unique([userId, text])
}

model User {
  id               String   @id
  name             String   @default("ローカルユーザー")
  slug             String   @unique @default("local-user")
  recoveryCodeHash String?
  createdAt        DateTime @default(now())
  words            Word[]
}
