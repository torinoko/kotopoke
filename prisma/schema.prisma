generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Kotoba {
  id             String        @id
  text           String        @unique
  defaultReading String?
  defaultMeaning String?
  senses         KotobaSense[]
  userKotobas    UserKotoba[]
}

model User {
  id               String       @id
  name             String       @default("ローカルユーザー")
  slug             String       @unique @default("local-user")
  passwordHash     String?
  recoveryCodeHash String?
  isPublic         Boolean      @default(false)
  createdAt        DateTime     @default(now())
  userKotobas      UserKotoba[]
}

model UserKotoba {
  id          String       @id
  kotobaId    String
  senseId     String?
  userId      String?
  reading     String?
  meaning     String?
  source      String?
  impression  String?
  collectedAt String
  kotoba      Kotoba       @relation(fields: [kotobaId], references: [id], onDelete: Cascade)
  sense       KotobaSense? @relation(fields: [senseId], references: [id], onDelete: SetNull)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([kotobaId])
  @@index([senseId])
}

model KotobaSense {
  id          String       @id
  kotobaId    String
  reading     String
  kotoba      Kotoba       @relation(fields: [kotobaId], references: [id], onDelete: Cascade)
  userKotobas UserKotoba[]

  @@unique([kotobaId, reading])
  @@index([kotobaId])
}
